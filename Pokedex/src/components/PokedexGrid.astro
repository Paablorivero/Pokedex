---
import { PokeService } from '../services/pokemon.service';
import PokemonCard from './PokemonCard.astro';
import { TYPE_CONFIG } from '../data/type-config';

const pokemons = await PokeService.getPokedex();
const allTypes = Object.values(TYPE_CONFIG);
---

<main class="pokedex">
    <header class="pokedex-header">
        <div class="header-top">
            <a href="/" class="back-link" aria-label="Volver al inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <div class="header-lens" aria-hidden="true">
                <div class="lens-outer">
                    <div class="lens-inner"></div>
                    <div class="lens-shine"></div>
                </div>
            </div>
            <div class="header-info">
                <h1>Pokédex</h1>
                <p class="pokemon-count">{pokemons.length} Pokémon cargados</p>
            </div>
        </div>
        <p class="instruction">Pulsa un Pokémon para ver sus estadísticas</p>
    </header>

    <section class="type-legend">
        <div class="legend-container">
            <h3 class="legend-title">Tipos</h3>
            <div class="legend-items">
                {allTypes.map(ti => (
                    <div class="legend-item">
                        <span class="legend-badge" style={`background-color: ${ti.color};`}>{ti.icon}</span>
                        <span class="legend-name">{ti.nameEs}</span>
                    </div>
                ))}
            </div>
            <a href="/tipos" class="legend-link">Ver equivalencias de tipo →</a>
        </div>
    </section>

    <section class="filters-bar">
        <div class="filters-container">
            <div class="filter-group">
                <label for="name-filter" class="filter-label">Buscar</label>
                <div class="search-input-wrapper">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" id="name-filter" placeholder="Nombre del Pokémon..." autocomplete="off" />
                </div>
            </div>
            <div class="filter-group">
                <label for="gen-filter" class="filter-label">Generación</label>
                <select id="gen-filter">
                    <option value="all">Todas</option>
                    <option value="1">1ª Gen (1-151)</option>
                    <option value="2">2ª Gen (152-251)</option>
                    <option value="3">3ª Gen (252-386)</option>
                    <option value="4">4ª Gen (387-493)</option>
                    <option value="5">5ª Gen (494-649)</option>
                    <option value="6">6ª Gen (650-721)</option>
                    <option value="7">7ª Gen (722-809)</option>
                    <option value="8">8ª Gen (810-905)</option>
                    <option value="9">9ª Gen (906-1025)</option>
                </select>
            </div>
            <p class="results-count" id="results-count"></p>
        </div>
    </section>

    <section class="pokedex-grid" id="pokedex-grid">
        {pokemons.map((poke) => (
            <PokemonCard pokemon={poke} />
        ))}
    </section>

    <p class="no-results" id="no-results" style="display:none;">No se encontraron Pokémon con esos filtros.</p>
</main>

<script>
    const nameInput = document.getElementById('name-filter') as HTMLInputElement;
    const genSelect = document.getElementById('gen-filter') as HTMLSelectElement;
    const grid = document.getElementById('pokedex-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLAnchorElement>('.card-link'));
    const countEl = document.getElementById('results-count')!;
    const noResults = document.getElementById('no-results')!;

    function applyFilters() {
        const nameQuery = nameInput.value.toLowerCase().trim();
        const genValue = genSelect.value;
        let visible = 0;

        for (const card of cards) {
            const name = card.dataset.name || '';
            const gen = card.dataset.gen || '';
            const matchesName = !nameQuery || name.includes(nameQuery);
            const matchesGen = genValue === 'all' || gen === genValue;
            const show = matchesName && matchesGen;
            (card as HTMLElement).style.display = show ? '' : 'none';
            if (show) visible++;
        }

        countEl.textContent = `${visible} resultado${visible !== 1 ? 's' : ''}`;
        noResults.style.display = visible === 0 ? '' : 'none';
    }

    nameInput.addEventListener('input', applyFilters);
    genSelect.addEventListener('change', applyFilters);
    applyFilters();
</script>

<style>
    .pokedex {
        min-height: 100vh;
        background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
        padding-bottom: 3rem;
    }

    .pokedex-header {
        background: linear-gradient(135deg, #DC0A2D 0%, #a00820 100%);
        padding: 1.5rem 2rem 1.2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
    }

    .pokedex-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #333 0%, #555 50%, #333 100%);
    }

    .header-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .back-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        text-decoration: none;
        transition: background 0.2s;
        flex-shrink: 0;
    }

    .back-link:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .back-link svg {
        width: 20px;
        height: 20px;
    }

    .header-lens {
        flex-shrink: 0;
    }

    .lens-outer {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #1b6d9c;
        border: 3px solid #e8e8e8;
        position: relative;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .lens-inner {
        position: absolute;
        inset: 4px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #58d0f8, #1b8dcc 60%, #0f5f8a);
    }

    .lens-shine {
        position: absolute;
        top: 8px;
        left: 10px;
        width: 14px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
    }

    .header-info {
        flex: 1;
    }

    h1 {
        margin: 0;
        font-size: 1.8rem;
        color: #fff;
        font-weight: 800;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .pokemon-count {
        margin: 0.2rem 0 0;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.9rem;
    }

    .instruction {
        max-width: 1400px;
        margin: 0.8rem auto 0;
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.85rem;
        padding-left: 104px;
    }

    /* ---- Filters ---- */
    .filters-bar {
        max-width: 1400px;
        margin: 0 auto 1.5rem;
        padding: 0 2rem;
    }

    .filters-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 1.2rem 1.5rem;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 180px;
    }

    .filter-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 600;
    }

    .search-input-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        color: rgba(255, 255, 255, 0.3);
        pointer-events: none;
    }

    #name-filter {
        width: 100%;
        padding: 0.6rem 0.8rem 0.6rem 2.4rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        color: #e8e8e8;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
        box-sizing: border-box;
    }

    #name-filter::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }

    #name-filter:focus {
        border-color: #DC0A2D;
        background: rgba(255, 255, 255, 0.08);
    }

    #gen-filter {
        padding: 0.6rem 0.8rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        color: #e8e8e8;
        font-size: 0.9rem;
        outline: none;
        cursor: pointer;
        transition: border-color 0.2s;
        box-sizing: border-box;
        width: 100%;
    }

    #gen-filter:focus {
        border-color: #DC0A2D;
    }

    #gen-filter option {
        background: #1e1e38;
        color: #e8e8e8;
    }

    .results-count {
        margin: 0;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.35);
        align-self: flex-end;
        padding-bottom: 0.3rem;
        white-space: nowrap;
    }

    /* ---- Type legend ---- */
    .type-legend {
        max-width: 1400px;
        margin: 0 auto 1.5rem;
        padding: 0 2rem;
    }

    .legend-container {
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 1rem 1.5rem;
    }

    .legend-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 600;
        margin: 0 0 0.7rem;
    }

    .legend-items {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .legend-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        font-size: 0.65rem;
        line-height: 1;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
    }

    .legend-name {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 500;
    }

    .legend-link {
        display: inline-block;
        margin-top: 0.7rem;
        font-size: 0.78rem;
        color: #DC0A2D;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .legend-link:hover {
        color: #ff4d4d;
    }

    .no-results {
        text-align: center;
        color: rgba(255, 255, 255, 0.4);
        font-size: 1rem;
        padding: 3rem 1rem;
    }

    .pokedex-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: 1rem;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    @media (max-width: 600px) {
        .pokedex-header {
            padding: 1.2rem 1rem 1rem;
        }

        .instruction {
            padding-left: 0;
            text-align: center;
        }

        .filters-bar,
        .type-legend {
            padding: 0 1rem;
        }

        .filters-container {
            flex-direction: column;
            padding: 1rem;
        }

        .filter-group {
            min-width: unset;
        }

        .legend-container {
            padding: 0.8rem 1rem;
        }

        .legend-items {
            gap: 0.4rem 0.8rem;
        }

        .pokedex-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 0.8rem;
            padding: 0 1rem;
        }

        .lens-outer {
            width: 36px;
            height: 36px;
        }

        h1 {
            font-size: 1.4rem;
        }
    }
</style>
