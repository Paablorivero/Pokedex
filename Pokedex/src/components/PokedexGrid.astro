---
import { PokeService } from '../services/pokemon.service';
import PokemonCard from './PokemonCard.astro';

const pokemons = await PokeService.getPokedex();
---

<main class="pokedex">
    <header class="pokedex-header">
        <div class="header-top">
            <a href="/" class="back-link" aria-label="Volver al inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <div class="header-lens" aria-hidden="true">
                <div class="lens-outer">
                    <div class="lens-inner"></div>
                    <div class="lens-shine"></div>
                </div>
            </div>
            <div class="header-info">
                <h1>Pokédex</h1>
                <p class="pokemon-count">{pokemons.length} Pokémon cargados</p>
            </div>
        </div>
        <p class="instruction">Pulsa un Pokémon para ver sus estadísticas</p>
    </header>

    <section class="pokedex-grid">
        {pokemons.map((poke) => (
            <PokemonCard pokemon={poke} />
        ))}
    </section>
</main>

<style>
    .pokedex {
        min-height: 100vh;
        background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
        padding-bottom: 3rem;
    }

    .pokedex-header {
        background: linear-gradient(135deg, #DC0A2D 0%, #a00820 100%);
        padding: 1.5rem 2rem 1.2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
    }

    .pokedex-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #333 0%, #555 50%, #333 100%);
    }

    .header-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .back-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        text-decoration: none;
        transition: background 0.2s;
        flex-shrink: 0;
    }

    .back-link:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .back-link svg {
        width: 20px;
        height: 20px;
    }

    .header-lens {
        flex-shrink: 0;
    }

    .lens-outer {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #1b6d9c;
        border: 3px solid #e8e8e8;
        position: relative;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .lens-inner {
        position: absolute;
        inset: 4px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #58d0f8, #1b8dcc 60%, #0f5f8a);
    }

    .lens-shine {
        position: absolute;
        top: 8px;
        left: 10px;
        width: 14px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
    }

    .header-info {
        flex: 1;
    }

    h1 {
        margin: 0;
        font-size: 1.8rem;
        color: #fff;
        font-weight: 800;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .pokemon-count {
        margin: 0.2rem 0 0;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.9rem;
    }

    .instruction {
        max-width: 1400px;
        margin: 0.8rem auto 0;
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.85rem;
        padding-left: 104px;
    }

    .pokedex-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: 1rem;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    @media (max-width: 600px) {
        .pokedex-header {
            padding: 1.2rem 1rem 1rem;
        }

        .instruction {
            padding-left: 0;
            text-align: center;
        }

        .pokedex-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 0.8rem;
            padding: 0 1rem;
        }

        .lens-outer {
            width: 36px;
            height: 36px;
        }

        h1 {
            font-size: 1.4rem;
        }
    }
</style>
