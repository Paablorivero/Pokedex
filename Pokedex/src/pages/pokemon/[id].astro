---
import Layout from '../../layouts/Layout.astro';
import { PokeService } from '../../services/pokemon.service';
import type { Pokemon } from '../../types/pokemon';

export async function getStaticPaths() {
    const pokemons = await PokeService.getPokedex();
    return pokemons.map((pokemon) => ({
        params: { id: pokemon.id.toString() },
        props: { pokemon },
    }));
}

interface Props {
    pokemon: Pokemon;
}

const { pokemon } = Astro.props;

const MAX_STAT = 255;

const statConfig = [
    { label: 'HP',        key: 'hp' as const,             color: '#FF5959' },
    { label: 'Ataque',    key: 'attack' as const,         color: '#F5AC78' },
    { label: 'Defensa',   key: 'defense' as const,        color: '#FAE078' },
    { label: 'Atq. Esp.', key: 'specialAttack' as const,  color: '#9DB7F5' },
    { label: 'Def. Esp.', key: 'specialDefense' as const, color: '#A7DB8D' },
    { label: 'Velocidad', key: 'speed' as const,          color: '#FA92B2' },
];

---

<Layout title={`${pokemon.nombre} | Pokédex`} description={`Estadísticas de ${pokemon.nombre}.`}>
    <main class="detail-page">
        <nav class="top-bar">
            <a href="/pokedex" class="back-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Pokédex
            </a>
            <span class="nav-id">#{pokemon.id.toString().padStart(3, '0')}</span>
        </nav>

        <section class="pokemon-showcase">
            <div class="showcase-bg" aria-hidden="true">
                <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="2"/>
                    <line x1="10" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="2"/>
                    <circle cx="100" cy="100" r="25" fill="none" stroke="currentColor" stroke-width="2"/>
                </svg>
            </div>
            <img 
                src={pokemon.images.extra_front} 
                alt={pokemon.nombre}
                class="pokemon-art"
                onerror={`this.src='${pokemon.images.back}';`}
            />
        </section>

        <section class="info-panel">
            <h1 class="pokemon-name">{pokemon.nombre}</h1>

            <div class="two-columns">
                <div class="col-left">
                    <div class="stats-section">
                        <h2 class="section-title">Estadísticas Base</h2>
                        <div class="stats-list">
                            {statConfig.map((stat) => {
                                const value = pokemon.stats[stat.key];
                                const pct = Math.round((value / MAX_STAT) * 100);
                                return (
                                    <div class="stat-row">
                                        <span class="stat-label">{stat.label}</span>
                                        <span class="stat-value">{value}</span>
                                        <div class="bar-track">
                                            <div 
                                                class="bar-fill"
                                                style={`width: ${pct}%; background-color: ${stat.color};`}
                                            />
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                </div>

                <div class="col-right">
                    {pokemon.frontSprites.length > 0 && (
                        <div class="sprites-section">
                            <h2 class="section-title">Estilos</h2>
                            <div class="sprites-gallery">
                                {pokemon.frontSprites.map((sprite) => (
                                    <button class="sprite-item" data-src={sprite.url} data-label={`${pokemon.nombre} - ${sprite.label}`}>
                                        <img 
                                            src={sprite.url}
                                            alt={`${pokemon.nombre} - ${sprite.label}`}
                                            loading="lazy"
                                            decoding="async"
                                            onerror="this.closest('.sprite-item').style.display='none';"
                                        />
                                        <span class="sprite-label">{sprite.label}</span>
                                        <span class="preview-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/>
                                            </svg>
                                        </span>
                                    </button>
                                ))}
                            </div>
                        </div>
                    )}
                </div>
            </div>

            <div class="nav-pokemon">
                {pokemon.id > 1 && (
                    <a href={`/pokemon/${pokemon.id - 1}`} class="nav-link prev">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        #{(pokemon.id - 1).toString().padStart(3, '0')}
                    </a>
                )}
                <span class="nav-spacer"></span>
                {pokemon.id < 1350 && (
                    <a href={`/pokemon/${pokemon.id + 1}`} class="nav-link next">
                        #{(pokemon.id + 1).toString().padStart(3, '0')}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
                    </a>
                )}
            </div>
        </section>

        <div class="lightbox" id="lightbox" aria-hidden="true">
            <div class="lightbox-backdrop"></div>
            <div class="lightbox-content">
                <button class="lightbox-close" aria-label="Cerrar vista previa">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
                <img id="lightbox-img" src="" alt="" />
                <p class="lightbox-label" id="lightbox-label"></p>
            </div>
        </div>
    </main>
</Layout>

<script>
    const lightbox = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbLabel = document.getElementById('lightbox-label')!;
    const lbClose = lightbox.querySelector('.lightbox-close')!;
    const lbBackdrop = lightbox.querySelector('.lightbox-backdrop')!;

    document.querySelectorAll<HTMLButtonElement>('.sprite-item[data-src]').forEach(btn => {
        btn.addEventListener('click', () => {
            lbImg.src = btn.dataset.src || '';
            lbImg.alt = btn.dataset.label || '';
            lbLabel.textContent = btn.dataset.label || '';
            lightbox.classList.add('active');
            lightbox.setAttribute('aria-hidden', 'false');
        });
    });

    function closeLightbox() {
        lightbox.classList.remove('active');
        lightbox.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
    }

    lbClose.addEventListener('click', closeLightbox);
    lbBackdrop.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });
</script>
    </main>
</Layout>

<style>
    .detail-page {
        min-height: 100vh;
        background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
    }

    /* ---- Top navigation ---- */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #DC0A2D 0%, #a00820 100%);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        position: relative;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #333 0%, #555 50%, #333 100%);
    }

    .back-btn {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        transition: background 0.2s;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .back-btn svg {
        width: 20px;
        height: 20px;
    }

    .nav-id {
        color: rgba(255, 255, 255, 0.7);
        font-weight: 700;
        font-size: 1.1rem;
        font-variant-numeric: tabular-nums;
    }

    /* ---- Pokemon showcase ---- */
    .pokemon-showcase {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem;
        position: relative;
        min-height: 260px;
    }

    .showcase-bg {
        position: absolute;
        width: 220px;
        height: 220px;
        color: rgba(255, 255, 255, 0.04);
        animation: spin 60s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .pokemon-art {
        position: relative;
        width: 200px;
        height: 200px;
        object-fit: contain;
        filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    /* ---- Info panel ---- */
    .info-panel {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem 3rem;
    }

    .pokemon-name {
        text-transform: capitalize;
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        text-align: center;
        margin: 0 0 2rem;
    }

    /* ---- Two-column layout ---- */
    .two-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    .col-left,
    .col-right {
        min-width: 0;
    }

    /* ---- Shared section title ---- */
    .section-title {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.4);
        margin: 0 0 1.2rem;
        font-weight: 600;
    }

    /* ---- Sprites gallery ---- */
    .sprites-section {
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 1.5rem;
        height: 100%;
    }

    .sprites-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 0.8rem;
    }

    .sprite-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 0.7rem 0.4rem;
        transition: border-color 0.2s, transform 0.2s;
        cursor: pointer;
        position: relative;
        font-family: inherit;
        color: inherit;
    }

    .sprite-item:hover {
        border-color: rgba(220, 10, 45, 0.3);
        transform: translateY(-2px);
    }

    .sprite-item img {
        width: 70px;
        height: 70px;
        object-fit: contain;
        image-rendering: auto;
        filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.3));
    }

    .sprite-label {
        font-size: 0.65rem;
        color: rgba(255, 255, 255, 0.45);
        text-align: center;
        font-weight: 500;
        line-height: 1.2;
    }

    .preview-icon {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 18px;
        height: 18px;
        color: rgba(255, 255, 255, 0.15);
        transition: color 0.2s;
    }

    .preview-icon svg {
        width: 100%;
        height: 100%;
    }

    .sprite-item:hover .preview-icon {
        color: rgba(220, 10, 45, 0.6);
    }

    /* ---- Stats ---- */
    .stats-section {
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 1.5rem;
        height: 100%;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .stat-row {
        display: grid;
        grid-template-columns: 90px 40px 1fr;
        align-items: center;
        gap: 0.8rem;
    }

    .stat-label {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 500;
    }

    .stat-value {
        font-size: 0.9rem;
        color: #e8e8e8;
        font-weight: 700;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .bar-track {
        height: 8px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ---- Lightbox ---- */
    .lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }

    .lightbox.active {
        opacity: 1;
        pointer-events: auto;
    }

    .lightbox-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(6px);
    }

    .lightbox-content {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 2rem;
        max-width: 90vw;
        max-height: 90vh;
        transform: scale(0.9);
        transition: transform 0.25s ease;
    }

    .lightbox.active .lightbox-content {
        transform: scale(1);
    }

    .lightbox-content img {
        max-width: 320px;
        max-height: 320px;
        width: auto;
        height: auto;
        object-fit: contain;
        filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
    }

    .lightbox-label {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        text-transform: capitalize;
        font-weight: 500;
    }

    .lightbox-close {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, color 0.2s;
    }

    .lightbox-close:hover {
        background: rgba(220, 10, 45, 0.3);
        color: #fff;
    }

    .lightbox-close svg {
        width: 18px;
        height: 18px;
    }

    /* ---- Prev / Next navigation ---- */
    .nav-pokemon {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
    }

    .nav-spacer {
        flex: 1;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: color 0.2s, border-color 0.2s, background 0.2s;
        font-variant-numeric: tabular-nums;
    }

    .nav-link:hover {
        color: #fff;
        border-color: rgba(220, 10, 45, 0.4);
        background: rgba(220, 10, 45, 0.1);
    }

    .nav-link svg {
        width: 16px;
        height: 16px;
    }

    /* ---- Responsive ---- */
    @media (max-width: 768px) {
        .two-columns {
            grid-template-columns: 1fr;
        }

        .info-panel {
            max-width: 600px;
        }
    }

    @media (max-width: 480px) {
        .top-bar {
            padding: 0.8rem 1rem;
        }

        .pokemon-showcase {
            min-height: 200px;
            padding: 1.5rem;
        }

        .pokemon-art {
            width: 150px;
            height: 150px;
        }

        .showcase-bg {
            width: 170px;
            height: 170px;
        }

        .info-panel {
            padding: 0 1rem 2rem;
        }

        .pokemon-name {
            font-size: 1.8rem;
        }

        .stat-row {
            grid-template-columns: 75px 35px 1fr;
            gap: 0.5rem;
        }

        .stat-label {
            font-size: 0.78rem;
        }

        .lightbox-content {
            padding: 1.5rem;
        }

        .lightbox-content img {
            max-width: 240px;
            max-height: 240px;
        }
    }
</style>
