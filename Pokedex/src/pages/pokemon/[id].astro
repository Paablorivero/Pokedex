---
import Layout from '../../layouts/Layout.astro';
import { PokeService, type TypeRelations } from '../../services/pokemon.service';
import type { Pokemon } from '../../types/pokemon';
import { getTypeInfo, ALL_TYPE_NAMES } from '../../data/type-config';

export async function getStaticPaths() {
    const [pokemons, allTypeRelations] = await Promise.all([
        PokeService.getPokedex(),
        PokeService.getTypeRelations(),
    ]);

    const typeRelMap = new Map<string, TypeRelations>();
    for (const tr of allTypeRelations) {
        typeRelMap.set(tr.name, tr);
    }

    return pokemons.map((pokemon) => ({
        params: { id: pokemon.id.toString() },
        props: {
            pokemon,
            typeRelations: pokemon.types
                .map(t => typeRelMap.get(t))
                .filter(Boolean) as TypeRelations[],
        },
    }));
}

interface Props {
    pokemon: Pokemon;
    typeRelations: TypeRelations[];
}

const { pokemon, typeRelations } = Astro.props;

const MAX_STAT = 255;

const statConfig = [
    { label: 'HP',        key: 'hp' as const,             color: '#FF5959' },
    { label: 'Ataque',    key: 'attack' as const,         color: '#F5AC78' },
    { label: 'Defensa',   key: 'defense' as const,        color: '#FAE078' },
    { label: 'Atq. Esp.', key: 'specialAttack' as const,  color: '#9DB7F5' },
    { label: 'Def. Esp.', key: 'specialDefense' as const, color: '#A7DB8D' },
    { label: 'Velocidad', key: 'speed' as const,          color: '#FA92B2' },
];

// --- Combined type matchup calculation ---
function getDefensiveMultiplier(atkType: string, rels: TypeRelations[]): number {
    let mult = 1;
    for (const rel of rels) {
        if (rel.double_damage_from.includes(atkType)) mult *= 2;
        else if (rel.half_damage_from.includes(atkType)) mult *= 0.5;
        else if (rel.no_damage_from.includes(atkType)) mult *= 0;
    }
    return mult;
}

const defenseByMult: Record<string, string[]> = { '4': [], '2': [], '0.5': [], '0.25': [], '0': [] };
for (const atkType of ALL_TYPE_NAMES) {
    const m = getDefensiveMultiplier(atkType, typeRelations);
    const key = String(m);
    if (key in defenseByMult) defenseByMult[key].push(atkType);
}

const offenseStrong = [...new Set(typeRelations.flatMap(tr => tr.double_damage_to))];
const offenseWeak = [...new Set(typeRelations.flatMap(tr => tr.half_damage_to))].filter(t => !offenseStrong.includes(t));
const offenseNone = [...new Set(typeRelations.flatMap(tr => tr.no_damage_to))].filter(t => !offenseStrong.includes(t) && !offenseWeak.includes(t));

---

<Layout title={`${pokemon.nombre} | Pokédex`} description={`Estadísticas de ${pokemon.nombre}.`}>
    <main class="detail-page">
        <nav class="top-bar">
            <a href="/pokedex" class="back-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Pokédex
            </a>
            <span class="nav-id">#{pokemon.id.toString().padStart(3, '0')}</span>
        </nav>

        <section class="pokemon-showcase">
            <div class="showcase-bg" aria-hidden="true">
                <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="2"/>
                    <line x1="10" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="2"/>
                    <circle cx="100" cy="100" r="25" fill="none" stroke="currentColor" stroke-width="2"/>
                </svg>
            </div>
            <img 
                src={pokemon.images.extra_front} 
                alt={pokemon.nombre}
                class="pokemon-art"
                onerror={`this.src='${pokemon.images.back}';`}
            />
        </section>

        <section class="info-panel">
            <h1 class="pokemon-name">{pokemon.nombre}</h1>
            <div class="detail-type-badges">
                {pokemon.types.map(t => {
                    const ti = getTypeInfo(t);
                    return (
                        <span class="detail-type-badge" style={`background-color: ${ti.color};`}>
                            {ti.icon} {ti.nameEs}
                        </span>
                    );
                })}
            </div>

            <div class="two-columns">
                <div class="col-left">
                    <div class="stats-section">
                        <h2 class="section-title">Estadísticas Base</h2>
                        <div class="stats-list">
                            {statConfig.map((stat) => {
                                const value = pokemon.stats[stat.key];
                                const pct = Math.round((value / MAX_STAT) * 100);
                                return (
                                    <div class="stat-row">
                                        <span class="stat-label">{stat.label}</span>
                                        <span class="stat-value">{value}</span>
                                        <div class="bar-track">
                                            <div 
                                                class="bar-fill"
                                                style={`width: ${pct}%; background-color: ${stat.color};`}
                                            />
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                </div>

                <div class="col-right">
                    {typeRelations.length > 0 && (
                        <div class="type-matchups">
                            <h2 class="section-title">Equivalencias de Tipo</h2>

                            <div class="matchup-group">
                                <h3 class="matchup-subtitle">Atacando</h3>
                                {offenseStrong.length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-strong">Fuerte contra ×2</span>
                                        <div class="matchup-badges">
                                            {offenseStrong.map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {offenseWeak.length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-weak">Poco eficaz ×½</span>
                                        <div class="matchup-badges">
                                            {offenseWeak.map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {offenseNone.length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-immune">Sin efecto ×0</span>
                                        <div class="matchup-badges">
                                            {offenseNone.map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                            </div>

                            <div class="matchup-group">
                                <h3 class="matchup-subtitle">Defendiendo</h3>
                                {defenseByMult['4'].length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-very-vulnerable">Muy débil ×4</span>
                                        <div class="matchup-badges">
                                            {defenseByMult['4'].map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {defenseByMult['2'].length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-vulnerable">Débil ×2</span>
                                        <div class="matchup-badges">
                                            {defenseByMult['2'].map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {defenseByMult['0.5'].length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-resist">Resistente ×½</span>
                                        <div class="matchup-badges">
                                            {defenseByMult['0.5'].map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {defenseByMult['0.25'].length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-very-resist">Muy resistente ×¼</span>
                                        <div class="matchup-badges">
                                            {defenseByMult['0.25'].map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                                {defenseByMult['0'].length > 0 && (
                                    <div class="matchup-row">
                                        <span class="matchup-label m-total-immune">Inmune ×0</span>
                                        <div class="matchup-badges">
                                            {defenseByMult['0'].map(t => {
                                                const ti = getTypeInfo(t);
                                                return <span class="m-badge" style={`--badge-color:${ti.color};`}><span class="m-dot"></span>{ti.nameEs}</span>;
                                            })}
                                        </div>
                                    </div>
                                )}
                            </div>
                        </div>
                    )}
                </div>
            </div>

            <div class="nav-pokemon">
                {pokemon.id > 1 && (
                    <a href={`/pokemon/${pokemon.id - 1}`} class="nav-link prev">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        #{(pokemon.id - 1).toString().padStart(3, '0')}
                    </a>
                )}
                <span class="nav-spacer"></span>
                {pokemon.id < 1350 && (
                    <a href={`/pokemon/${pokemon.id + 1}`} class="nav-link next">
                        #{(pokemon.id + 1).toString().padStart(3, '0')}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
                    </a>
                )}
            </div>
        </section>

    </main>
</Layout>

<style>
    .detail-page {
        min-height: 100vh;
        background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
    }

    /* ---- Top navigation ---- */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #DC0A2D 0%, #a00820 100%);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        position: relative;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #333 0%, #555 50%, #333 100%);
    }

    .back-btn {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        transition: background 0.2s;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .back-btn svg {
        width: 20px;
        height: 20px;
    }

    .nav-id {
        color: rgba(255, 255, 255, 0.7);
        font-weight: 700;
        font-size: 1.1rem;
        font-variant-numeric: tabular-nums;
    }

    /* ---- Pokemon showcase ---- */
    .pokemon-showcase {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem;
        position: relative;
        min-height: 260px;
    }

    .showcase-bg {
        position: absolute;
        width: 220px;
        height: 220px;
        color: rgba(255, 255, 255, 0.04);
        animation: spin 60s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .pokemon-art {
        position: relative;
        width: 200px;
        height: 200px;
        object-fit: contain;
        filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    /* ---- Info panel ---- */
    .info-panel {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem 3rem;
    }

    .pokemon-name {
        text-transform: capitalize;
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        text-align: center;
        margin: 0 0 2rem;
    }

    /* ---- Two-column layout ---- */
    .two-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    .col-left,
    .col-right {
        min-width: 0;
    }

    /* ---- Shared section title ---- */
    .section-title {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.4);
        margin: 0 0 1.2rem;
        font-weight: 600;
    }

    /* ---- Stats ---- */
    .stats-section {
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 1.5rem;
        height: 100%;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .stat-row {
        display: grid;
        grid-template-columns: 90px 40px 1fr;
        align-items: center;
        gap: 0.8rem;
    }

    .stat-label {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 500;
    }

    .stat-value {
        font-size: 0.9rem;
        color: #e8e8e8;
        font-weight: 700;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .bar-track {
        height: 8px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ---- Detail type badges (below name) ---- */
    .detail-type-badges {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .detail-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #fff;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }

    /* ---- Type matchups (combined) ---- */
    .type-matchups {
        background: linear-gradient(145deg, #2a2a4a 0%, #1e1e38 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 1.5rem;
    }

    .matchup-group {
        margin-bottom: 1rem;
    }

    .matchup-group:last-child {
        margin-bottom: 0;
    }

    .matchup-subtitle {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 700;
        margin: 0 0 0.6rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .matchup-row {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin-bottom: 0.5rem;
    }

    .matchup-row:last-child {
        margin-bottom: 0;
    }

    .matchup-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 700;
    }

    .matchup-label.m-strong        { color: #4ade80; }
    .matchup-label.m-weak          { color: #fb923c; }
    .matchup-label.m-immune        { color: #94a3b8; }
    .matchup-label.m-very-vulnerable { color: #ef4444; }
    .matchup-label.m-vulnerable    { color: #f87171; }
    .matchup-label.m-resist        { color: #60a5fa; }
    .matchup-label.m-very-resist   { color: #34d399; }
    .matchup-label.m-total-immune  { color: #c084fc; }

    .matchup-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    .m-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.2rem 0.55rem 0.2rem 0.4rem;
        border-radius: 6px;
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        background: rgba(255, 255, 255, 0.07);
        border-left: 3px solid var(--badge-color);
        white-space: nowrap;
    }

    .m-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--badge-color);
        flex-shrink: 0;
    }

    /* ---- Prev / Next navigation ---- */
    .nav-pokemon {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
    }

    .nav-spacer {
        flex: 1;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: color 0.2s, border-color 0.2s, background 0.2s;
        font-variant-numeric: tabular-nums;
    }

    .nav-link:hover {
        color: #fff;
        border-color: rgba(220, 10, 45, 0.4);
        background: rgba(220, 10, 45, 0.1);
    }

    .nav-link svg {
        width: 16px;
        height: 16px;
    }

    /* ---- Responsive ---- */
    @media (max-width: 768px) {
        .two-columns {
            grid-template-columns: 1fr;
        }

        .info-panel {
            max-width: 600px;
        }
    }

    @media (max-width: 480px) {
        .top-bar {
            padding: 0.8rem 1rem;
        }

        .pokemon-showcase {
            min-height: 200px;
            padding: 1.5rem;
        }

        .pokemon-art {
            width: 150px;
            height: 150px;
        }

        .showcase-bg {
            width: 170px;
            height: 170px;
        }

        .info-panel {
            padding: 0 1rem 2rem;
        }

        .pokemon-name {
            font-size: 1.8rem;
        }

        .stat-row {
            grid-template-columns: 75px 35px 1fr;
            gap: 0.5rem;
        }

        .stat-label {
            font-size: 0.78rem;
        }

        .lightbox-content {
            padding: 1.5rem;
        }

        .lightbox-content img {
            max-width: 240px;
            max-height: 240px;
        }
    }
</style>
